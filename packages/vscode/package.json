{
  "name": "@waml/vscode",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "commonjs",
  "displayName": "WAML",
  "description": "Live WAML diagnostics for Markdown documents.",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Programming Languages", "Linters"],
  "activationEvents": ["onLanguage:markdown"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "WAML",
      "properties": {
        "waml.serverPath": {
          "type": "string",
          "default": "waml",
          "description": "Path to the waml executable that provides the language server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": { "vscode-languageclient": "^9.0.1" },
  "devDependencies": { "@types/vscode": "^1.90.0", "typescript": "^5.6.0", "vitest": "^2.1.0" }
}
